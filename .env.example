# API base URL. Use SAME_ORIGIN (or leave empty) when deploying on Netlify so
# /api/* is proxied to the backend via netlify.toml.
# In local dev, SAME_ORIGIN resolves to http://localhost:3000 automatically.
VITE_API_BASE_URL=SAME_ORIGIN

# Optional: override the local API URL (defaults to http://localhost:3000)
# VITE_DEV_API_URL=http://localhost:3000

# Optional: override the Vite dev proxy target (only used if you keep SAME_ORIGIN
# requests going through the Vite server instead of direct API calls)
# VITE_DEV_API_PROXY=http://localhost:3000
